<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Minimal TestNG suite that registers the TestLookup listener.

  The single <listener> entry is the only line you need to add to an existing
  testng.xml — TestLookupListener picks up its config from
  src/test/resources/testlookup.properties (and from JVM system properties /
  env vars / suite parameters as overrides).

  When no configuration is found the listener silently no-ops, so leaving it
  registered in environments without TestLookup is safe.
-->
<suite name="Smoke Suite" verbose="1">
    <listeners>
        <listener class-name="io.testlookup.testng.TestLookupListener"/>
    </listeners>

    <test name="smoke">
        <classes>
            <class name="com.example.SmokeTests"/>
            <class name="com.example.AuthTests"/>
        </classes>
    </test>
</suite>
